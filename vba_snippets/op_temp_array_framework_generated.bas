Private Sub ResolveSourceColumns(ByVal ws As Worksheet, ByVal headerRow As Long, _
                                 ByVal useHeaderLookup As Boolean, ByVal sourceHeaders As Variant, _
                                 ByVal fallbackCols As Variant, ByRef sourceCols() As Long)
    Dim i As Long

    For i = LBound(sourceHeaders) To UBound(sourceHeaders)
        sourceCols(i) = 0

        If useHeaderLookup And Len(CStr(sourceHeaders(i))) > 0 Then
            sourceCols(i) = HeaderColumn(ws, CStr(sourceHeaders(i)), headerRow)
        End If

        If sourceCols(i) = 0 Then
            sourceCols(i) = CLng(fallbackCols(i))
        End If
    Next i
End Sub

Private Function FirstMappedValue(ByVal ws As Worksheet, ByVal rowNumber As Long, _
                                  ByRef sourceCols() As Long, ByVal targetHeaders As Variant, _
                                  ByVal keywords As Variant) As String
    Dim i As Long
    Dim k As Long
    Dim headerKey As String
    Dim keywordKey As String

    For i = LBound(targetHeaders) To UBound(targetHeaders)
        If sourceCols(i) > 0 Then
            headerKey = NormalizeKey(CStr(targetHeaders(i)))
            For k = LBound(keywords) To UBound(keywords)
                keywordKey = NormalizeKey(CStr(keywords(k)))
                If Len(keywordKey) > 0 Then
                    If InStr(1, headerKey, keywordKey, vbTextCompare) > 0 Or _
                       InStr(1, keywordKey, headerKey, vbTextCompare) > 0 Then
                        FirstMappedValue = CleanCellText(ws.Cells(rowNumber, sourceCols(i)).Text)
                        Exit Function
                    End If
                End If
            Next k
        End If
    Next i

    FirstMappedValue = vbNullString
End Function

Private Function PrefixValue(ByVal prefixText As String, ByVal value As String) As String
    value = CleanCellText(value)
    If Len(value) = 0 Then
        PrefixValue = vbNullString
    Else
        PrefixValue = prefixText & value
    End If
End Function

Private Function CleanNumberText(ByVal value As String) As String
    Dim i As Long
    Dim ch As String
    Dim result As String

    value = CleanCellText(value)
    For i = 1 To Len(value)
        ch = Mid$(value, i, 1)
        If (ch >= "0" And ch <= "9") Or ch = "." Or ch = "-" Then
            result = result & ch
        End If
    Next i

    CleanNumberText = result
End Function

Private Function DefaultText(ByVal value As String, ByVal fallback As String) As String
    value = CleanCellText(value)
    If Len(value) = 0 Then
        DefaultText = fallback
    Else
        DefaultText = value
    End If
End Function

Private Function CollectionCount(ByVal items As Collection) As Long
    On Error Resume Next
    CollectionCount = items.Count
    If Err.Number <> 0 Then CollectionCount = 0
    On Error GoTo 0
End Function

Private Function SheetExists(ByVal sheetName As String) As Boolean
    Dim ws As Worksheet

    On Error Resume Next
    Set ws = ThisWorkbook.Worksheets(sheetName)
    On Error GoTo 0

    SheetExists = Not ws Is Nothing
End Function

Private Function HeaderColumn(ByVal ws As Worksheet, ByVal headerText As String, ByVal headerRow As Long) As Long
    Dim lastCol As Long
    Dim lookupKey As String
    Dim cellKey As String
    Dim c As Long

    lastCol = ws.Cells(headerRow, ws.Columns.Count).End(xlToLeft).Column
    lookupKey = NormalizeKey(headerText)

    For c = 1 To lastCol
        cellKey = NormalizeKey(ws.Cells(headerRow, c).Text)
        If cellKey = lookupKey Then
            HeaderColumn = c
            Exit Function
        End If
    Next c

    For c = 1 To lastCol
        cellKey = NormalizeKey(ws.Cells(headerRow, c).Text)
        If Len(cellKey) > 0 Then
            If InStr(1, cellKey, lookupKey, vbTextCompare) > 0 Or InStr(1, lookupKey, cellKey, vbTextCompare) > 0 Then
                HeaderColumn = c
                Exit Function
            End If
        End If
    Next c

    HeaderColumn = 0
End Function

Private Function RowHasMappedData(ByVal ws As Worksheet, ByVal rowNumber As Long, ByRef sourceCols() As Long) As Boolean
    Dim i As Long

    For i = LBound(sourceCols) To UBound(sourceCols)
        If sourceCols(i) > 0 Then
            If Len(CleanCellText(ws.Cells(rowNumber, sourceCols(i)).Text)) > 0 Then
                RowHasMappedData = True
                Exit Function
            End If
        End If
    Next i

    RowHasMappedData = False
End Function

Private Function LastUsedRow(ByVal ws As Worksheet) As Long
    Dim found As Range

    Set found = ws.Cells.Find(What:="*", LookIn:=xlFormulas, SearchOrder:=xlByRows, SearchDirection:=xlPrevious)
    If found Is Nothing Then
        LastUsedRow = 1
    Else
        LastUsedRow = found.Row
    End If
End Function

Private Function CleanCellText(ByVal value As Variant) As String
    Dim text As String

    text = CStr(value)
    text = Replace(text, Chr(13), " ")
    text = Replace(text, Chr(10), " ")
    text = Replace(text, Chr(9), " ")
    text = Application.WorksheetFunction.Trim(text)

    CleanCellText = text
End Function

Private Function NormalizeKey(ByVal value As Variant) As String
    Dim text As String

    text = LCase$(CleanCellText(value))
    text = Replace(text, " ", "")
    text = Replace(text, "_", "")
    text = Replace(text, "-", "")
    text = Replace(text, ".", "")
    text = Replace(text, "/", "")
    text = Replace(text, ":", "")
    text = Replace(text, "#", "")
    text = Replace(text, "&", "")
    text = Replace(text, "'", "")
    text = Replace(text, "(", "")
    text = Replace(text, ")", "")

    NormalizeKey = text
End Function
