            Call TINV(Inv, GetOrCreateSheet("Tinv"))
        Else
            MsgBox "無法提取 TINV 資料，請確認 " & "Inv" & " 已匯入", vbExclamation
        End If
    End If
    If SheetExists("Pkg") Then
        Set Pkg = WB.Worksheets("Pkg")
        If WorksheetFunction.CountA(Pkg.UsedRange) <> 0 Then
            Call TPKG(Pkg, GetOrCreateSheet("Tpkg"), GetOrCreateSheet("Tinv"))
        End If
    End If

    MsgBox "完成：INVcollection=" & CollectionCount(INVcollection) & _
           "，PKGcollection=" & CollectionCount(PKGcollection), vbInformation
End Sub

